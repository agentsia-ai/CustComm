# ============================================================
# CustComm — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# --- Anthropic (required) ---
# Powers intent classification and reply drafting.
ANTHROPIC_API_KEY=sk-ant-...

# --- Gmail API (recommended primary inbox + sender in v1) ---
# Path to the OAuth2 client credentials JSON downloaded from Google Cloud Console
# (APIs & Services → Credentials → "Desktop app" → Download JSON).
GMAIL_CREDENTIALS_PATH=./credentials.json

# Path where the OAuth2 refresh token will be cached after the first auth dance.
# Safe to leave at the default; .gitignored.
GMAIL_TOKEN_PATH=./.gmail_token.json

# --- SMTP (fallback send path; used if outreach.backend = "smtp") ---
# Gmail app-password docs: https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=

# --- IMAP (planned; stubbed in v1) ---
# Listed here so the shape is complete; IMAP inbox backend is not wired up yet.
IMAP_HOST=
IMAP_USERNAME=
IMAP_PASSWORD=

# --- App Settings ---
# Path to the config YAML the engine should load. Defaults to ./config.yaml.
CONFIG_PATH=config.yaml

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
